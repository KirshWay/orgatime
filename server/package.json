    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.21",
    "@types/archiver": "7.0.0",
    "@types/node": "25.5.0",
    "@types/passport-jwt": "4.0.1",
    "@types/uuid": "10.0.0",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "source-map-support": "0.5.21",
