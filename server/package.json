    "@nestjs/common": "11.1.17",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.17",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mapped-types": "2.1.1",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-fastify": "11.1.17",
    "@nestjs/swagger": "11.2.6",
    "@prisma/client": "6.19.2",
    "archiver": "7.0.1",
    "bcryptjs": "3.0.3",
    "class-transformer": "0.5.1",
